{
  "name": "claude-frontend-cli",
  "version": "0.2.0",
  "description": "Firmowy installer konfiguracji Claude Code dla projektów frontend (Nuxt/Vue/TS) — docs, skille, agent, settings i CLAUDE.md z jednej komendy.",
  "type": "module",
  "bin": {
    "cfc": "./dist/index.js"
  },
  "files": [
    "dist",
    "content",
    "skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "frontend",
    "nuxt",
    "vue",
    "scaffolding",
    "skills"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "oxlint": "^0.9.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
